PORT=3000

# Meta / Facebook Messenger
VERIFY_TOKEN=make-a-long-random-verify-token
PAGE_ACCESS_TOKEN=EAAB...
PAGE_ID=1234567890
APP_SECRET=
GRAPH_API_VERSION=v25.0

# Your public HTTPS URL, for example https://xxxx.ngrok-free.app
PUBLIC_BASE_URL=

# OpenAI
AI_PROVIDER=openai
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-5.4
OPENAI_FALLBACK_MODEL=gpt-4o-mini
OPENAI_PRIMARY_TIMEOUT_MS=12000
OPENAI_REASONING_EFFORT=medium
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_VOICE=marin

# Free-tier alternative for text chat
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Bot behavior
BOT_NAME=Tro Ly Facebook AI
VOICE_REPLIES_DEFAULT=false
AI_REPLY_TIMEOUT_MS=30000
MAX_HISTORY_MESSAGES=16
MAX_MEMORY_FACTS=40
MEMORY_FILE_PATH=
REPORT_FILE_PATH=
