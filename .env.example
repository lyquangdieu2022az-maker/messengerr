PORT=3000

# Meta / Facebook Messenger
VERIFY_TOKEN=make-a-long-random-verify-token
PAGE_ACCESS_TOKEN=EAAB...
PAGE_ID=1234567890
APP_SECRET=
GRAPH_API_VERSION=v25.0

# Your public HTTPS URL, for example https://xxxx.ngrok-free.app
PUBLIC_BASE_URL=

# AI chat
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODELS=gemini-2.5-flash
GEMINI_MAX_RETRIES=1

# Optional Llama / Meta-style AI through OpenAI-compatible providers
# AI_PROVIDER can be: gemini, groq, openrouter, llama, openai
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Tro Ly Facebook AI
LLAMA_API_KEY=
LLAMA_BASE_URL=
LLAMA_MODEL=
LLAMA_FALLBACK_MODELS=
LLAMA_MAX_RETRIES=1

# Bot behavior
BOT_NAME=Tro Ly Facebook AI
VOICE_REPLIES_DEFAULT=false
SETUP_MESSENGER_PROFILE_ON_START=true
SETUP_MESSENGER_GREETING_ON_START=false
AI_REPLY_TIMEOUT_MS=30000
MAX_HISTORY_MESSAGES=16
MAX_MEMORY_FACTS=40
MEMORY_FILE_PATH=
REPORT_FILE_PATH=

# Automatic Page posting and comment replies
# Keep false until your Meta app has the required Page permissions and feed webhook subscription.
AUTO_POST_ENABLED=false
AUTO_POST_TIMES=08:00,12:00,16:00
AUTO_POST_UTC_OFFSET_MINUTES=420
AUTO_POST_CATCH_UP_MINUTES=90
AUTO_POST_CHECK_INTERVAL_MS=300000
AUTO_POST_SIGNATURE=Nguồn tham khảo: Trung tâm trợ giúp Facebook/Meta. Nội dung do Page tự biên soạn, không đại diện Meta.
COMMENT_AUTO_REPLY_ENABLED=false
COMMENT_REPLY_TTL_DAYS=14
AUTOMATION_FILE_PATH=
