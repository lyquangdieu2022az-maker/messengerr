PORT=3000

# Meta / Facebook Messenger
VERIFY_TOKEN=make-a-long-random-verify-token
PAGE_ACCESS_TOKEN=EAAB...
PAGE_ID=1234567890
APP_SECRET=
GRAPH_API_VERSION=v25.0

# Your public HTTPS URL, for example https://xxxx.ngrok-free.app
PUBLIC_BASE_URL=

# AI chat
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Bot behavior
BOT_NAME=Tro Ly Facebook AI
VOICE_REPLIES_DEFAULT=false
SETUP_MESSENGER_PROFILE_ON_START=true
SETUP_MESSENGER_GREETING_ON_START=false
AI_REPLY_TIMEOUT_MS=30000
MAX_HISTORY_MESSAGES=16
MAX_MEMORY_FACTS=40
MEMORY_FILE_PATH=
REPORT_FILE_PATH=
